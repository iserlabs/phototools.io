{
  "name": "phototools.io",
  "version": "1.0.0",
  "description": "Free photography calculators, simulators, and references",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3200",
    "build": "next build",
    "postbuild": "node scripts/indexnow-push.mjs || echo 'IndexNow push skipped (INDEXNOW_KEY not set or non-prod env)'",
    "start": "next start -p 3200",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.52.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "advanced-cropper": "^0.17.1",
    "exifreader": "^4.38.1",
    "jpeg-js": "^0.4.4",
    "next": "^16.2.6",
    "next-intl": "^4.11.1",
    "posthog-js": "^1.372.10",
    "react": "^19.2.6",
    "react-advanced-cropper": "^0.20.1",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "upng-js": "^2.1.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@next/eslint-plugin-next": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
